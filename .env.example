# Copy this file to .env and fill in your local paths.
# .env is git-ignored by design — never commit it.

# ---------------------------------------------------------------------------
# LLM (Llama 3.1 8B + DPO adapter)
# ---------------------------------------------------------------------------
# Hugging Face model ID or local path to the base model
BASE_MODEL_NAME=meta-llama/Meta-Llama-3.1-8B-Instruct

# Local path to your DPO adapter checkpoint (required)
ADAPTER_PATH=D:\Work\AI\results_reframebot_DPO\checkpoint-90

# ---------------------------------------------------------------------------
# Guardrail classifier (DistilBERT)
# ---------------------------------------------------------------------------
# Local path to the trained guardrail model directory
# Auto-discovery order if unset:
#   1. ./guardrail_model_retrained/best
#   2. ./guardrail_model/checkpoint-950
GUARDRAIL_PATH=D:\Work\AI\guardrail_model_retrained\best

# Number of recent user turns to feed to the guardrail classifier
GUARDRAIL_CONTEXT_TURNS=3

# Max characters of concatenated user turns sent to the classifier
GUARDRAIL_CONTEXT_MAX_CHARS=700

# ---------------------------------------------------------------------------
# RAG database
# ---------------------------------------------------------------------------
# Path to the ChromaDB directory (created by scripts/build_rag_db.py)
RAG_DB_PATH=./rag_db

# ---------------------------------------------------------------------------
# Embedder (shared by guardrail semantic detector + RAG)
# ---------------------------------------------------------------------------
ROUTER_EMBED_MODEL=all-MiniLM-L6-v2

# ---------------------------------------------------------------------------
# Crisis detection thresholds
# ---------------------------------------------------------------------------
# Minimum cosine similarity to a crisis prototype to trigger the semantic detector
CRISIS_SEMANTIC_SIM_THRESHOLD=0.62

# Minimum margin between crisis_sim and academic_sim to avoid false positives
CRISIS_SEMANTIC_SIM_MARGIN=0.08

# Guardrail confidence above which a TASK_2 prediction is treated as high-confidence
CRISIS_CONFIDENCE_THRESHOLD=0.90

# ---------------------------------------------------------------------------
# API server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# Comma-separated list of allowed CORS origins (use * for development only)
# CORS_ORIGINS=http://localhost:8080,https://yourdomain.com

# ---------------------------------------------------------------------------
# Hugging Face (required only for push_model_cards.py / push_to_hub.py)
# ---------------------------------------------------------------------------
# HF_TOKEN=hf_...
# SFT_ADAPTER_PATH=D:\Work\AI\results_reframebot_llama3\checkpoint-423
